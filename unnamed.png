[functions]
  directory = "netlify/functions/"
  node_bundler = "esbuild"

[[blobs]]
  store = "subscriptions"

[[headers]]
  for = "/sw.js"
  [headers.values]
    Cache-Control = "no-cache"
    Service-Worker-Allowed = "/"

[[headers]]
  for = "/*"
  [headers.values]
    X-Frame-Options = "DENY"
    X-Content-Type-Options = "nosniff"
